REACT_DEVTOOLS_ENABLED=true
REACT_DEVTOOLS_AUTO_START=true
REACT_DEVTOOLS_FORCE_FETCH=false
REACT_DEVTOOLS_PORT=8097
REACT_DEVTOOLS_CACHE_DURATION=86400000

# Build diagnostics
# Set to true or 1 to emit production build source maps for Performance tooling.
# Keep disabled for normal release packaging to avoid larger artifacts and source exposure.
AAH_BUILD_SOURCEMAP=false

# Product analytics
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# Real-site E2E
# AAH_E2E_NEW_API_BASE_URL=https://new-api.example.com
# AAH_E2E_NEW_API_USERNAME=test-user
# AAH_E2E_NEW_API_PASSWORD=replace-with-test-password
# AAH_E2E_NEW_API_LOGIN_PATH=/login
# AAH_E2E_NEW_API_LOGIN_API_PATH=/api/user/login
# AAH_E2E_NEW_API_LOGIN_2FA_API_PATH=/api/user/login/2fa
# AAH_E2E_NEW_API_USERNAME_SELECTOR=
# AAH_E2E_NEW_API_PASSWORD_SELECTOR=
# AAH_E2E_NEW_API_SUBMIT_SELECTOR=
# AAH_E2E_NEW_API_AGREE_SELECTOR=
