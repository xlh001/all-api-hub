{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "~": ["./src"],
      "~/*": ["./src/*"],
      "~~": ["."],
      "~~/*": ["./*"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true
  },
  "include": ["src", "tests", "e2e", "*.config.*", "scripts"],
  "exclude": [
    "node_modules",
    ".output",
    "coverage",
    "diagnostics-results",
    "playwright-report",
    "test-results"
  ]
}
